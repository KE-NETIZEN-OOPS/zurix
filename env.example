# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_ADMIN_KEY=your-service-role-key

# Cloudflare R2
CF_R2_ACCOUNT_ID=your-account-id
CF_R2_ACCESS_KEY_ID=your-access-key
CF_R2_SECRET_ACCESS_KEY=your-secret-key
CF_R2_BUCKET=zurix-media
CF_R2_PUBLIC_URL=https://your-bucket.r2.dev
NEXT_PUBLIC_R2_PUBLIC_URL=https://your-bucket.r2.dev

# Site URL
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# M-Pesa Daraja
DARAJA_CONSUMER_KEY=your-consumer-key
DARAJA_CONSUMER_SECRET=your-consumer-secret
DARAJA_SHORTCODE=174379
DARAJA_PASSKEY=your-passkey
DARAJA_CALLBACK_URL=https://yourdomain.com/api/payments/mpesa/callback

# Pesapal
PESAPAL_CONSUMER_KEY=your-key
PESAPAL_CONSUMER_SECRET=your-secret
PESAPAL_ENV=sandbox

# NOWPayments
NOWPAYMENTS_API_KEY=your-api-key
NOWPAYMENTS_IPN_SECRET=your-ipn-secret

# Streaming (boss-server)
RTMP_SERVER_URL=http://your-vps-ip
RTMP_INGEST_URL=rtmp://your-vps-ip

# Chaturbate (optional)
CHATURBATE_AFFILIATE_ID=your-affiliate-id

# Persona KYC (face + ID verification). Leave blank to fall back to photo-verify.
NEXT_PUBLIC_PERSONA_TEMPLATE_ID=itmpl_xxx
NEXT_PUBLIC_PERSONA_ENVIRONMENT_ID=env_xxx
PERSONA_API_KEY=persona_sandbox_xxx
PERSONA_WEBHOOK_SECRET=wbhsec_xxx
